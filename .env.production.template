# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=omni-one-backend
APP_VERSION=1.0.0
BUILD_NUMBER=1

# ─── Security ─────────────────────────────────────────────────────────────────
# Update this with your actual production domain
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─── Auth (Phase 16.3) ──────────────────────────────────────────────────────
# Generate these securely (e.g., using `openssl rand -hex 32`)
JWT_SECRET=replace-me-with-32-byte-secure-random-string
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
COOKIE_SECRET=replace-me-with-32-byte-secure-random-string

# ─── OAuth (Phase 16.3) ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Encryption (Phase 16.3) ────────────────────────────────────────────────
# Must be exactly 32 characters long
ENCRYPTION_KEY=replace-me-with-32-byte-secure-key!

# ─── AI Providers ─────────────────────────────────────────────────────────────
# Set these in your CI/CD secrets or production environment
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=false

# ─── Database (Phase 16.2) ──────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-me-with-secure-db-password
POSTGRES_DB=omni_one
# This matches the internal docker network routing
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=public

# ─── Redis (Phase 16.2) ─────────────────────────────────────────────────────
# This matches the internal docker network routing
REDIS_URL=redis://redis:6379

# ─── Storage (Phase 16.2) ───────────────────────────────────────────────────
# Use 's3' in production if possible, otherwise 'local' will use the Docker volume
STORAGE_PROVIDER=local
STORAGE_PATH=/app/storage

# S3 Configuration (if STORAGE_PROVIDER=s3)
S3_REGION=us-east-1
S3_BUCKET=omni-one-assets-prod
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
