# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=omni-one-backend
APP_VERSION=1.0.0
BUILD_NUMBER=1

# ─── Security ─────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─── Auth (Phase 16.3) ──────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
COOKIE_SECRET=your-super-secret-cookie-key

# ─── OAuth (Phase 16.3) ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Encryption (Phase 16.3) ────────────────────────────────────────────────
ENCRYPTION_KEY=32-character-long-encryption-key-!!

# ─── AI Providers ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=true

# ─── Database (Phase 16.2) ──────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/omni_one?schema=public

# ─── Redis (Phase 16.2) ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Storage (Phase 16.2) ───────────────────────────────────────────────────
STORAGE_PROVIDER=local
STORAGE_PATH=./storage
S3_REGION=us-east-1
S3_BUCKET=omni-one-assets
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=

# ─── Manus AI Provider ─────────────────────────────────────────────────────
MANUS_API_KEY=
