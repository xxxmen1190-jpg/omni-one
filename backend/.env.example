# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=omni-one-backend
APP_VERSION=1.0.0
BUILD_NUMBER=1

# ─── Security ─────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─── AI Providers ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=true

