// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

// ─── User & Identity ──────────────────────────────────────────────────────────

model User {
  id              String         @id @default(uuid())
  email           String         @unique
  passwordHash    String?        // Null for OAuth-only users
  username        String?        @unique
  displayName     String?
  avatarUrl       String?
  bio             String?        @db.Text
  timezone        String         @default("UTC")
  language        String         @default("en")
  
  role            UserRole       @default(USER)
  status          UserStatus     @default(ACTIVE)
  plan            String         @default("FREE")
  
  emailVerified   Boolean        @default(false)
  lastSeenAt      DateTime?
  preferences     Json?          // Theme, AI defaults, Privacy, etc.
  
  conversations   Conversation[]
  projects        Project[]
  apiKeys         ApiKey[]
  notifications   Notification[]
  auditLogs       AuditLog[]
  sessions        Session[]
  oauthAccounts   OAuthAccount[]
  feedbacks       Feedback[]
  installations   MarketplaceInstallation[]
  reviews         MarketplaceReview[]
  workflows       Workflow[]
  advancedMemory  AdvancedMemory[]
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([email])
  @@index([username])
}

enum UserRole {
  OWNER
  ADMIN
  USER
  GUEST
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

model OAuthAccount {
  id                String   @id @default(uuid())
  userId            String
  provider          String   // "google" | "github"
  providerUserId    String   // ID from provider
  accessToken       String?  @db.Text
  refreshToken      String?  @db.Text
  expiresAt         DateTime?
  
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerUserId])
  @@index([userId])
}

model Session {
  id            String    @id @default(uuid())
  userId        String
  tokenHash     String    @unique
  deviceName    String?
  browser       String?
  os            String?
  ip            String?
  userAgent     String?
  country       String?
  isActive      Boolean   @default(true)
  lastUsedAt    DateTime  @default(now())
  expiresAt     DateTime
  
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime  @default(now())

  @@index([userId])
}

// ─── Chat & Messaging ─────────────────────────────────────────────────────────

model Conversation {
  id          String    @id @default(uuid())
  title       String?
  userId      String
  projectId   String?
  summary     String?   @db.Text
  metadata    Json?          // Provider info, token counts, etc.
  isPinned    Boolean   @default(false)
  isFavorite  Boolean   @default(false)
  isArchived  Boolean   @default(false)
  isDeleted   Boolean   @default(false)
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  messages    Message[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([projectId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  role           MessageRole
  content        String       @db.Text
  tokens         Int?
  model          String?
  metadata       Json?        // Tool calls, reasoning, etc.
  
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  createdAt      DateTime     @default(now())

  @@index([conversationId])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

// ─── Projects & Workspace ─────────────────────────────────────────────────────

model Project {
  id            String         @id @default(uuid())
  name          String
  description   String?        @db.Text
  userId        String
  metadata      Json?
  
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  files         File[]
  tasks         Task[]
  
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([userId])
}

// ─── Memory & Knowledge (RAG) ─────────────────────────────────────────────────

model Memory {
  id          String                      @id @default(uuid())
  userId      String
  content     String                      @db.Text
  metadata    Json?
  embedding   Unsupported("vector(1536)")? // For OpenAI embeddings
  
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt

  @@index([userId])
}

// ─── File Persistence ─────────────────────────────────────────────────────────

model File {
  id          String    @id @default(uuid())
  name        String
  size        Int
  mimeType    String
  key         String    @unique // Storage provider key (S3/Local)
  provider    String    // "S3" | "LOCAL"
  projectId   String?
  metadata    Json?
  
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([projectId])
}

// ─── Agents & Tasks ───────────────────────────────────────────────────────────

model Agent {
  id          String      @id @default(uuid())
  name        String
  type        String      // "research" | "code" | "automation"
  config      Json?
  status      AgentStatus @default(IDLE)
  
  tasks       Task[]
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

enum AgentStatus {
  IDLE
  RUNNING
  MAINTENANCE
  DEPRECATED
}

model Task {
  id          String     @id @default(uuid())
  projectId   String?
  agentId     String?
  title       String
  description String?    @db.Text
  status      TaskStatus @default(PENDING)
  priority    Int        @default(0)
  result      Json?
  
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  agent       Agent?     @relation(fields: [agentId], references: [id], onDelete: SetNull)
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([projectId])
  @@index([agentId])
}

enum TaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

// ─── Security & Audit ─────────────────────────────────────────────────────────

model ApiKey {
  id          String    @id @default(uuid())
  userId      String
  name        String
  keyPrefix   String    // First 8 chars
  hash        String    @unique
  scopes      String[]  // ["chat:read", "tools:execute"]
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime  @default(now())

  @@index([userId])
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  action      String
  resource    String
  resourceId  String?
  metadata    Json?
  ip          String?
  userAgent   String?
  
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([action])
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  title       String
  message     String
  type        String   // "info" | "warning" | "error" | "success"
  read        Boolean  @default(false)
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([read])
}

// ─── Phase 19: Beta & Feedback ────────────────────────────────────────────────

model Feedback {
  id             String       @id @default(uuid())
  userId         String
  conversationId String?
  messageId      String?
  
  rating         Int          // 1 (👍) or -1 (👎)
  comment        String?      @db.Text
  
  // Context for evaluation
  model          String?
  provider       String?
  toolsUsed      String[]
  confidence     Float?
  metadata       Json?        // Full evaluation metrics (relevance, etc.)
  
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt      DateTime     @default(now())

  @@index([userId])
  @@index([conversationId])
  @@index([messageId])
}

model BetaInvite {
  id          String    @id @default(uuid())
  code        String    @unique
  email       String?   // Optional target email
  maxUses     Int       @default(1)
  uses        Int       @default(0)
  expiresAt   DateTime?
  createdBy   String?
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([code])
}

model FeatureFlag {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isEnabled   Boolean  @default(false)
  rules       Json?    // User IDs, roles, or percentages
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
}

// Add relation to User model (note: this requires an edit to the User model as well, 
// but Prisma doesn't strictly require it in the schema if not used inversely)


// ─── Phase 20: Platform & Ecosystem ──────────────────────────────────────────

model MarketplaceItem {
  id              String         @id @default(uuid())
  type            MarketplaceType
  name            String
  description     String         @db.Text
  manifest        Json           // Permissions, required tools, models, etc.
  version         String
  author          String
  category        String
  tags            String[]
  iconUrl         String?
  bannerUrl       String?
  
  rating          Float          @default(0)
  reviewCount     Int            @default(0)
  installCount    Int            @default(0)
  
  isFeatured      Boolean        @default(false)
  isTrending      Boolean        @default(false)
  
  changelog       Json?          // Version history
  
  installations   MarketplaceInstallation[]
  reviews         MarketplaceReview[]
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([type])
  @@index([category])
  @@index([author])
}

enum MarketplaceType {
  AGENT
  SKILL
  PLUGIN
}

model MarketplaceInstallation {
  id              String          @id @default(uuid())
  userId          String
  itemId          String
  version         String
  isEnabled       Boolean         @default(true)
  config          Json?           // User-specific configuration
  
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  item            MarketplaceItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  
  installedAt     DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([userId, itemId])
  @@index([userId])
  @@index([itemId])
}

model MarketplaceReview {
  id              String          @id @default(uuid())
  userId          String
  itemId          String
  rating          Int
  comment         String?         @db.Text
  
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  item            MarketplaceItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime        @default(now())

  @@index([userId])
  @@index([itemId])
}

model Workflow {
  id              String          @id @default(uuid())
  userId          String
  name            String
  description     String?
  definition      Json            // Nodes, edges, conditions, loops
  status          WorkflowStatus  @default(DRAFT)
  
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  executions      WorkflowExecution[]
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([userId])
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
  DEPRECATED
}

model WorkflowExecution {
  id              String          @id @default(uuid())
  workflowId      String
  userId          String
  status          ExecutionStatus @default(PENDING)
  input           Json?
  output          Json?
  logs            Json?
  
  workflow        Workflow        @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  
  startedAt       DateTime?
  finishedAt      DateTime?
  createdAt       DateTime        @default(now())

  @@index([workflowId])
  @@index([userId])
}

enum ExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model AdvancedMemory {
  id              String          @id @default(uuid())
  userId          String
  type            MemoryType
  content         String          @db.Text
  embedding       Unsupported("vector(1536)")?
  importance      Float           @default(1.0)
  decay           Float           @default(1.0)
  lastAccessedAt  DateTime        @default(now())
  metadata        Json?
  
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([userId])
  @@index([type])
}

enum MemoryType {
  WORKING
  SESSION
  LONG_TERM
  PROJECT
  SEMANTIC
  PREFERENCE
}

